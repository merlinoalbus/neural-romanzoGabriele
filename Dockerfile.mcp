# ============================================================
# MCP Server - Rete Neurale Romanzo Gabriele
# ============================================================

FROM node:22-alpine AS build

WORKDIR /app
COPY mcp-server/package.json mcp-server/package-lock.json ./
RUN npm ci

COPY mcp-server/tsconfig.json ./
COPY mcp-server/src/ ./src/
RUN test -f ./src/services/embeddingService.ts \
  && grep -q "kg_embedding_status" ./src/toolNames.ts \
  && rm -f ./node_modules/.tmp/tsconfig.mcp.tsbuildinfo \
  && npm run build \
  && grep -q "kg_embedding_status" ./dist/toolNames.js

FROM node:22-alpine AS deps

WORKDIR /app
COPY mcp-server/package.json mcp-server/package-lock.json ./
RUN npm ci --omit=dev

FROM node:22-alpine

WORKDIR /app
RUN addgroup -S appgroup && adduser -S appuser -G appgroup

COPY --from=deps /app/node_modules ./node_modules
COPY --from=build /app/dist ./dist
COPY mcp-server/package.json ./
COPY mcp-server/instructions.md ./dist/instructions.md

ENV NODE_ENV=production
ENV MCP_PORT=3002

EXPOSE 3002
USER appuser

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD node -e "require('http').get('http://localhost:3002/healthz', r => process.exit(r.statusCode === 200 ? 0 : 1)).on('error', () => process.exit(1))"

CMD ["node", "dist/index.js"]
