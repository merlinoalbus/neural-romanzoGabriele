{
  "name": "neural-graph-platform-server",
  "version": "0.1.0",
  "description": "Internal backend for NAS storage and read-only graph APIs used by the frontend.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch --env-file=../.env src/index.ts",
    "typecheck": "tsc --noEmit --project tsconfig.json"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "neo4j-driver": "^6.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.0",
    "@types/express": "^5.0.0",
    "@types/node": "^24.12.0",
    "tsx": "^4.0.0",
    "typescript": "~5.9.3"
  }
}
