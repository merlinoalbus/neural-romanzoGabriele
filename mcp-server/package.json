{
  "name": "romanzo-gabriele-neural-mcp",
  "version": "0.1.0",
  "description": "MCP server for the Romanzo Gabriele narrative knowledge graph.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch --env-file=../.env src/index.ts",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "lint": "eslint src",
    "test": "node --import tsx --test \"src/**/*.test.ts\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "express": "^5.1.0",
    "neo4j-driver": "^6.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/express": "^5.0.0",
    "@types/node": "^24.12.0",
    "eslint": "^9.39.4",
    "globals": "^17.4.0",
    "tsx": "^4.0.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0"
  }
}
