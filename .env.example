PROJECT_ID=romanzo-gabriele
APP_ENV=production
APP_VERSION=0.1.0
LOG_LEVEL=info

FE_HOST_PORT=3000
MCP_HOST_PORT=3002
MCP_PORT=3002
MCP_URL=https://devrn-romanzo-mcp.nasmerlinoalbus.cloud/mcp
MCP_SHARED_SECRET=change-this-shared-secret
MCP_SSE_KEEPALIVE_MS=25000
MCP_SESSION_TTL_MS=1800000
MCP_SESSION_CLEANUP_INTERVAL_MS=300000
NEO4J_URI=bolt://romanzo_gabriele_neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-this-password-please

# Default: self-hosted Ollama sidecar (romanzo_gabriele_ollama), no API key needed.
# To use a paid provider instead (e.g. OpenAI), override these four and leave
# EMBEDDINGS_API_KEY/EMBEDDINGS_MODEL pointing at that provider.
EMBEDDINGS_PROVIDER=openai-compatible
EMBEDDINGS_API_KEY=ollama-local
EMBEDDINGS_BASE_URL=http://romanzo_gabriele_ollama:11434/v1
EMBEDDINGS_MODEL=nomic-embed-text
EMBEDDINGS_DIMENSIONS=768
EMBEDDINGS_TIMEOUT_MS=30000
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_EMBEDDING_MODEL=

WATCHTOWER_SCOPE=romanzo-gabriele-neural
